# Ignore everything by default
/*

# Allow only the project
!.gitignore
!Downloads/
Downloads/*
!Downloads/REVCONNECT-main/
Downloads/REVCONNECT-main/*
!Downloads/REVCONNECT-main/backend/
!Downloads/REVCONNECT-main/frontend/

# Backend ignores
Downloads/REVCONNECT-main/backend/target/
Downloads/REVCONNECT-main/backend/*.log
Downloads/REVCONNECT-main/backend/*.log.*
Downloads/REVCONNECT-main/backend/.mvn/wrapper/maven-wrapper.jar

# Frontend ignores
Downloads/REVCONNECT-main/frontend/node_modules/
Downloads/REVCONNECT-main/frontend/dist/
Downloads/REVCONNECT-main/frontend/.angular/

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Env
.env
*.pem
